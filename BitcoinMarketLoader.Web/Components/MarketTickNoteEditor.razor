@using BitcoinMarketLoader.Models
@using BitcoinMarketLoader.Services
@inject BitcoinMarketApiClient ApiClient

<div class="note-editor-backdrop">
    <section class="note-editor"
             role="dialog"
             aria-modal="true"
             aria-labelledby="note-editor-title">
        <div class="note-editor-header">
            <p class="eyebrow">Market tick</p>
            <h2 id="note-editor-title">Edit note</h2>
        </div>

        <dl class="note-editor-details">
            <div>
                <dt>CCSEQ</dt>
                <dd>@Tick.Ccseq</dd>
            </div>
            <div>
                <dt>Generated</dt>
                <dd>@Tick.GeneratedTimestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
            </div>
        </dl>

        <label class="note-editor-field">
            <span>Note</span>
            <textarea class="form-control"
                      rows="6"
                      maxlength="1024"
                      disabled="@isSaving"
                      @bind="noteDraft"></textarea>
            <small>@noteDraft.Length / 1024</small>
        </label>

        @if (!string.IsNullOrWhiteSpace(saveError))
        {
            <div class="alert alert-danger mb-0" role="alert">
                @saveError
            </div>
        }

        <div class="note-editor-actions">
            <button type="button"
                    class="btn btn-outline-danger delete-note-button"
                    disabled="@(isSaving || string.IsNullOrEmpty(Tick.Note))"
                    @onclick="DeleteAsync">
                Delete note
            </button>
            <button type="button"
                    class="btn btn-outline-secondary"
                    disabled="@isSaving"
                    @onclick="OnClosed">
                Close
            </button>
            <button type="button"
                    class="btn btn-primary"
                    disabled="@(isSaving || string.IsNullOrWhiteSpace(noteDraft))"
                    @onclick="SaveAsync">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>Save</span>
                }
            </button>
        </div>
    </section>
</div>

@code {
    [Parameter, EditorRequired]
    public MarketTickDto Tick { get; set; } = null!;

    [Parameter]
    public EventCallback OnClosed { get; set; }

    [Parameter]
    public EventCallback<string?> OnSaved { get; set; }

    private long? initializedTickId;
    private string noteDraft = string.Empty;
    private string? saveError;
    private bool isSaving;

    protected override void OnParametersSet()
    {
        if (initializedTickId == Tick.Ccseq)
        {
            return;
        }

        initializedTickId = Tick.Ccseq;
        noteDraft = Tick.Note ?? string.Empty;
        saveError = null;
    }

    private async Task SaveAsync()
    {
        if (isSaving || string.IsNullOrWhiteSpace(noteDraft))
        {
            return;
        }

        await PersistNoteAsync(noteDraft);
    }

    private Task DeleteAsync()
    {
        return string.IsNullOrEmpty(Tick.Note)
            ? Task.CompletedTask
            : PersistNoteAsync(string.Empty);
    }

    private async Task PersistNoteAsync(string note)
    {
        if (isSaving)
        {
            return;
        }

        isSaving = true;
        saveError = null;

        try
        {
            await ApiClient.UpdateMarketTickNoteAsync(Tick.Ccseq, note);
            await OnSaved.InvokeAsync(note);
        }
        catch (Exception exception) when (exception is HttpRequestException
                                          or TaskCanceledException
                                          or InvalidOperationException)
        {
            saveError = $"Unable to save the note: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
